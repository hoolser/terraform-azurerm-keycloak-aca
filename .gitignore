# =============================================================================
# Terraform — generated by: terraform init / plan / apply
# =============================================================================

# Provider binaries and modules downloaded by "terraform init" (~100MB+)
.terraform/
.terraform.lock.hcl

# Plan files generated by "terraform plan -out=..."
*.tfplan
*.tfplan.json

# Local state files generated by "terraform apply" (when no remote backend)
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# =============================================================================
# SECRETS — never commit these
# =============================================================================

# tfvars files contain real passwords, subscription IDs, secret keys
# Keep terraform.tfvars.example (if you create one) but never the real one
#terraform.tfvars
*.auto.tfvars

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# =============================================================================
# OS / Editor noise
# =============================================================================

# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store

# JetBrains IDEs (IntelliJ, Rider, etc.)
.idea/

# VS Code
.vscode/

# =============================================================================
# Notes
# =============================================================================
# terraform.tfvars  → gitignored (contains real secrets)
# terraform.tfvars.example → SAFE to commit (placeholder values only)
# .terraform.lock.hcl → some teams commit this to pin provider versions;
#                        it is gitignored here since this is a PoC.
#                        For production, remove .terraform.lock.hcl from
#                        this file so it gets committed and providers are pinned.

